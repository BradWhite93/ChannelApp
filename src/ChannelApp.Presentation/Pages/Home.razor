@page "/"
@inject NavigationManager NavigationManager
@inject AppState AppState
@implements IDisposable

<PageTitle>Channel App</PageTitle>

<div class="home-page">

    @if (!string.IsNullOrEmpty(AppState.LoadError))
    {
        <EmptyState Message="@AppState.LoadError" />
    }

    <div class="nav-tile-grid">
        <NavTile Label="My Favourites" OnClick="@(() => NavigationManager.NavigateTo("/channels?favourites=true"))" />
        <NavTile Label="Top Channels" OnClick="@(() => NavigationManager.NavigateTo("/channels?popular=true"))" />
        <NavTile Label="Browse by Category" OnClick="@(() => NavigationManager.NavigateTo("/categories"))" />
        <NavTile Label="Browse by Country" OnClick="@(() => NavigationManager.NavigateTo("/countries"))" />
        <NavTile Label="All Channels" OnClick="@(() => NavigationManager.NavigateTo("/channels"))" />
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}
