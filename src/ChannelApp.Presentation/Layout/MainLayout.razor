@inherits LayoutComponentBase
@implements IDisposable
@inject IChannelService ChannelService
@inject AppState AppState
@inject TextSizeService TextSizeService
@inject ThemeService ThemeService
@inject NavigationManager NavigationManager

<div class="app-layout">
    <div class="top-bar">
        <button class="home-btn" @onclick="GoHome" aria-label="Go home">🏠</button>
        <h1 class="top-bar-title">@PageTitle</h1>
        <button class="settings-cog" @onclick="ToggleSettings" aria-label="Settings">⚙️</button>
    </div>

    @if (!string.IsNullOrEmpty(AppState.LoadError))
    {
        <div class="error-notification" role="alert">@AppState.LoadError</div>
    }

    @Body

    <BottomNavBar />
</div>

@if (_settingsOpen)
{
    <div class="settings-overlay" @onclick="ToggleSettings">
        <div class="settings-panel" @onclick:stopPropagation="true">
            <div class="settings-header">
                <h2>Settings</h2>
                <button class="settings-close" @onclick="ToggleSettings" aria-label="Close settings">✕</button>
            </div>

            <div class="settings-section">
                <h3 class="settings-label">Text Size</h3>
                <div class="settings-options">
                    <button class="settings-btn @(IsTextSize(1.0) ? "active" : "")" @onclick="@(() => SetTextSize(1.0))">Normal</button>
                    <button class="settings-btn @(IsTextSize(1.25) ? "active" : "")" @onclick="@(() => SetTextSize(1.25))">Large</button>
                    <button class="settings-btn @(IsTextSize(1.5) ? "active" : "")" @onclick="@(() => SetTextSize(1.5))">Largest</button>
                </div>
            </div>

            <div class="settings-section">
                <h3 class="settings-label">Display</h3>
                <div class="settings-options">
                    <button class="settings-btn @(IsDarkMode() ? "active" : "")" @onclick="ToggleDarkMode">
                        @(IsDarkMode() ? "🌙 Dark Mode On" : "🌙 Dark Mode")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _settingsOpen = false;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;

        await TextSizeService.LoadAsync();
        await ThemeService.LoadAsync();

        try
        {
            var channels = await ChannelService.GetAllAsync();
            var favouriteIds = channels
                .Where(c => c.IsFavourite)
                .Select(c => c.Id)
                .ToHashSet();
            AppState.Initialise(channels, favouriteIds);
        }
        catch (Exception)
        {
            AppState.SetLoadError("Unable to load channel data. Please try again later.");
        }
    }

    private void ToggleSettings()
    {
        _settingsOpen = !_settingsOpen;
    }

    private bool IsTextSize(double multiplier) => Math.Abs(TextSizeService.CurrentMultiplier - multiplier) < 0.01;
    private bool IsDarkMode() => ThemeService.CurrentTheme == "dark";

    private async Task SetTextSize(double multiplier)
    {
        await TextSizeService.SetAsync(multiplier);
    }

    private async Task ToggleDarkMode()
    {
        await ThemeService.SetAsync(IsDarkMode() ? "normal" : "dark");
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("");
    }

    private string PageTitle
    {
        get
        {
            var uri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
            var parts = uri.Split('?');
            var path = parts[0].TrimStart('/');
            var query = parts.Length > 1 ? parts[1] : "";

            if (path == "channels" && query.Contains("popular=true", StringComparison.OrdinalIgnoreCase))
                return "Top Channels";

            return path switch
            {
                "" => "TV Channels",
                "categories" => "Categories",
                "countries" => "Countries",
                "channels" => "Channels",
                _ => "Channel App"
            };
        }
    }
}
