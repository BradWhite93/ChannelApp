<button class="playback-filter @(IsActive ? "active" : "")"
        @onclick="HandleClick"
        aria-pressed="@IsActive.ToString().ToLowerInvariant()"
        aria-label="Playback only">
    Playback only
</button>

@code {
    [Parameter]
    public bool IsActive { get; set; }

    [Parameter]
    public EventCallback<bool> OnToggle { get; set; }

    private async Task HandleClick()
    {
        await OnToggle.InvokeAsync(!IsActive);
    }
}
